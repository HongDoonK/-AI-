# Local environment files
.env
.env.*
!.env.example
!frontend/.env.example

# Editor-local settings
.vscode/
.claude/

# Python generated files and local virtualenvs
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Frontend dependencies and build output
node_modules/
frontend/node_modules/
dist/
frontend/dist/

# Runtime logs
logs/
*.log

# Generated embedding cache
data/index/

# Local databases (정책 DB는 재생성 스크립트로, 사용자 DB는 런타임 생성)
# 재생성: python -m backend.db && python -m backend.api_collector && python -m backend.preprocessing
data/*.db
*.db

# Test fixture DB는 스크립트로 생성 (tools/make_fixture_db.py)
tests/fixtures/

# AI 협업 산출물 (Claude Code ↔ codex) — 로컬 전용, GitHub 미게시
docs/AI_HANDOFF.md
reports/
/MEMORY.md
