YOUTH_POLICY_API_KEY=your_youth_policy_api_key
YOUTH_CENTER_API_KEY=your_youth_center_api_key

# ── LLM 설정 (ADR-002 §D2) ───────────────────────────────────────
# LLM은 비핵심 언어 계층이다. 비활성(none)이어도 규칙 fallback으로 완전 동작한다.
# LLM_PROVIDER ∈ {none, openai, hf, local}
#   none  : LLM 비활성 (기본·데모 권장). 규칙 fallback만 사용.
#   hf    : HuggingFace Inference API (HF_TOKEN 필요).
#   local : 로컬 transformers 추론 (오프라인, 최초 1회 모델 다운로드).
#   openai: 레거시 OpenAI (점진 폐기 대상).
LLM_PROVIDER=none
# 사용할 모델 (hf/local 공통). 기본 Qwen2.5-7B-Instruct(Apache-2.0).
# 저사양 폴백: Qwen/Qwen2.5-1.5B-Instruct
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# hf 공급자일 때만 필요
#HF_TOKEN=your_huggingface_token

# (레거시) openai 공급자용 — LLM_PROVIDER=openai일 때만 사용
#OPENAI_API_KEY=your_openai_api_key
#OPENAI_MODEL=gpt-4o-mini

# Embedding search settings
USE_FAISS=1

# Frontend CORS (쉼표로 구분된 허용 origin 목록, *.vercel.app은 자동 허용)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DB paths (선택 사항 - 비워두면 기본 경로 사용)
# 정책 데이터 DB (기본: youth_policy.db > data/youth_policy.db > backend/youth_policy.db 순서로 탐색)
#YOUTH_POLICY_DB_PATH=data/youth_policy.db
# 사용자 프로필 런타임 DB (기본: data/user_data.db, git에 올라가지 않음)
#USER_DB_PATH=data/user_data.db
